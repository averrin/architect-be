# Firebase
FIREBASE_SERVICE_ACCOUNT_JSON=firebase-service-account.json
FIREBASE_PROJECT_ID=ai-inbox-demo

# Scheduling
WEATHER_INTERVAL_MINUTES=60
NEWS_INTERVAL_MINUTES=30
BUXFER_INTERVAL_MINUTES=60
GITHUB_WATCHER_INTERVAL_MINUTES=2
JULES_INTERVAL_MINUTES=5
FORECAST_HOUR=7
MODELS_SYNC_INTERVAL_HOURS=24
COMMAND_POLL_INTERVAL_SECONDS=5

# Optional: Default API keys (fallback if user doesn't provide)
DEFAULT_GEMINI_API_KEY=
DEFAULT_NEWS_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
